<?xml version="1.0" encoding="utf-8"?>
<!--
    themes.xml
    Defines the visual theme and style of the application.
    Uses Material Components to ensure a modern and consistent look.
-->
<resources>

    <!-- Base application theme -->
    <style name="Theme.PhotoGallery" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>

        <!-- Main background color of the app windows -->
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Theme variant without an ActionBar, useful for splash screens if needed -->
    <style name="Theme.PhotoGallery.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
