<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_gallery.xml
    Layout for the Gallery screen which displays a grid of photos.
    Features:
    - Sticky header showing the current directory path.
    - RecyclerView for displaying thumbnails in a grid.
    - Empty state view that appears when no images are present in the folder.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header Section: Displays the folder path being browsed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_folder"
            android:layout_marginEnd="8dp"
            android:contentDescription="Folder Icon" />

        <TextView
            android:id="@+id/tvGalleryFolderPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:ellipsize="start"
            android:singleLine="true"
            android:text="Loading folder…" />

    </LinearLayout>

    <!-- Content Section -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Grid of images -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewImages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:clipToPadding="false" />

        <!-- View displayed only when the folder is empty -->
        <LinearLayout
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_image_placeholder"
                android:alpha="0.4"
                android:layout_marginBottom="16dp"
                android:contentDescription="No Images" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_images_message"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Take a photo or choose a different folder"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
