<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Main layout for the application's home screen.
    Features:
    - Welcome header with icon.
    - Status card showing the currently selected save directory.
    - Buttons to trigger photo capture, folder selection, and gallery viewing.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Branding Section -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_camera"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="App Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Capture, organize and browse your photos"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="40dp" />

        <!-- Selected Folder Information Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Save Folder"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvSelectedFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:ellipsize="middle"
                    android:singleLine="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Primary Action Buttons -->
        <Button
            android:id="@+id/btnTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📷  Take Photo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnChooseFolder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📁  Choose Folder"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/secondary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnViewGallery"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🖼️  View Gallery"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
