<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_image_detail.xml
    Layout for the Image Details screen.
    Displays:
    - A full-size preview of the selected image.
    - A card containing metadata (Name, Path, Size, Date).
    - A delete button to remove the image.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Viewer: Center-cropped preview of the photo -->
        <ImageView
            android:id="@+id/ivDetailImage"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:scaleType="centerCrop"
            android:background="#000000"
            android:contentDescription="@string/app_name" />

        <!-- Metadata Section: Displays file details in a card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_image_details"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <!-- Name Detail Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="📄"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvImageName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_image_name"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Path Detail Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="📁"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvImagePath"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_image_path"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Size Detail Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="💾"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvImageSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_image_size"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Date Detail Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvImageDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_image_date"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Delete Action -->
        <Button
            android:id="@+id/btnDeleteImage"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:text="@string/btn_delete"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/error" />

    </LinearLayout>
</ScrollView>
